<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>全屏·横竖适配星星收集</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      -webkit-user-select: none;
    }
    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #0a0f1e; /* 深色背景防止闪烁 */
      touch-action: pan-y pinch-zoom; /* 页面整体不滚动, 但画布内会禁用 */
    }
    canvas {
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;      /* 禁止画布内滚动/缩放 */
      background: #1a2330;     /* 画布底色 */
      cursor: none;            /* 移动端隐藏光标, 更干净 */
    }
  </style>
</head>
<body>
  <canvas id="gameCanvas"></canvas>
  <script>
    (function() {
      // ----- 获取画布与上下文 -----
      const canvas = document.getElementById('gameCanvas');
      const ctx = canvas.getContext('2d');

      // ----- 游戏全局变量 -----
      let playerX = 0, playerY = 0;            // 玩家当前绝对坐标 (像素)
      let targetX = 0, targetY = 0;              // 玩家目标坐标 (触摸点)
      const MOVE_SPEED = 0.12;                    // 平滑移动系数 (0~1)
      const COLLIDE_RADIUS = 38;                   // 碰撞/收集半径 (像素) 适中偏大, 方便触屏

      let stars = [];                              // 星星数组: 存储相对坐标 {relX, relY}
      const STAR_COUNT = 12;                       // 星星总数
      let score = 0;                               // 得分

      // 触摸/鼠标状态
      let isPointerDown = false;                    // 鼠标/触摸按下 (用于mouse move控制)
      
      // ----- 辅助函数: 生成不紧贴玩家的星星 (相对坐标) -----
      function createStarAvoidingPlayer(avoidX, avoidY, minDist, maxAttempts = 30) {
        for (let attempt = 0; attempt < maxAttempts; attempt++) {
          const relX = Math.random();
          const relY = Math.random();
          const absX = relX * canvas.width;
          const absY = relY * canvas.height;
          const dx = absX - avoidX;
          const dy = absY - avoidY;
          const dist = Math.hypot(dx, dy);
          if (dist > minDist) {
            return { relX, relY };
          }
        }
        // 保底: 返回完全随机 (极小概率会重叠, 但下一帧会被收集并再次生成)
        return { relX: Math.random(), relY: Math.random() };
      }

      // ----- 初始化星星 (避开玩家初始位置) -----
      function initStars(count, avoidX, avoidY) {
        const newStars = [];
        for (let i = 0; i < count; i++) {
          newStars.push(createStarAvoidingPlayer(avoidX, avoidY, COLLIDE_RADIUS));
        }
        return newStars;
      }

      // ----- 重置画布尺寸 & 修正玩家/目标边界 -----
      function resizeCanvas() {
        // 设置画布内部像素尺寸 = 窗口逻辑像素 (保证1:1映射)
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        // 如果玩家坐标超出新边界, 拉回内部 (一般不会, 但安全处理)
        if (playerX !== undefined) {
          playerX = Math.min(Math.max(playerX, 0), canvas.width);
          playerY = Math.min(Math.max(playerY, 0), canvas.height);
        } else {
          // 首次初始化时
          playerX = canvas.width / 2;
          playerY = canvas.height / 2;
        }

        // 目标点同步到玩家位置 (避免突变)
        targetX = playerX;
        targetY = playerY;

        // 不需要重新生成星星, 因为它们基于相对坐标, 会自动适配新画布
        // 但为了视觉效果, 可以重绘一次 (下一帧动画会做)
      }

      // ----- 事件处理：坐标转换 (client -> canvas 绝对像素) -----
      function getCanvasCoordsFromClient(clientX, clientY) {
        const rect = canvas.getBoundingClientRect();
        // 计算相对于 canvas CSS 的比例, 再映射到 canvas 内部像素
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        let canvasX = (clientX - rect.left) * scaleX;
        let canvasY = (clientY - rect.top) * scaleY;
        // 边界裁剪
        canvasX = Math.min(Math.max(canvasX, 0), canvas.width);
        canvasY = Math.min(Math.max(canvasY, 0), canvas.height);
        return { x: canvasX, y: canvasY };
      }

      // ----- 触摸事件 -----
      function handleTouchStart(e) {
        e.preventDefault();  // 阻止滚动/缩放
        const touch = e.touches[0];
        if (!touch) return;
        const { x, y } = getCanvasCoordsFromClient(touch.clientX, touch.clientY);
        targetX = x;
        targetY = y;
        isPointerDown = true;
      }

      function handleTouchMove(e) {
        e.preventDefault();
        const touch = e.touches[0];
        if (!touch) return;
        const { x, y } = getCanvasCoordsFromClient(touch.clientX, touch.clientY);
        targetX = x;
        targetY = y;
      }

      function handleTouchEnd(e) {
        e.preventDefault();
        // 手指离开: 让目标停在玩家当前位置, 即停止移动
        targetX = playerX;
        targetY = playerY;
        isPointerDown = false;
      }

      // ----- 鼠标事件 (便于开发调试, 同时兼容一些触摸板) -----
      function handleMouseDown(e) {
        e.preventDefault();
        const { x, y } = getCanvasCoordsFromClient(e.clientX, e.clientY);
        targetX = x;
        targetY = y;
        isPointerDown = true;
      }

      function handleMouseMove(e) {
        if (!isPointerDown) return; // 只有按下时才移动目标
        e.preventDefault();
        const { x, y } = getCanvasCoordsFromClient(e.clientX, e.clientY);
        targetX = x;
        targetY = y;
      }

      function handleMouseUp(e) {
        e.preventDefault();
        // 鼠标释放: 停止移动
        targetX = playerX;
        targetY = playerY;
        isPointerDown = false;
      }

      // 鼠标离开画布时也视为停止 (避免卡目标)
      function handleMouseLeave(e) {
        if (isPointerDown) {
          targetX = playerX;
          targetY = playerY;
          isPointerDown = false;
        }
      }

      // ----- 窗口旋转 / 尺寸变化 -----
      window.addEventListener('resize', () => {
        resizeCanvas();
        // 额外: 确保目标点不超出 (resizeCanvas 已做)
        // 星星相对坐标无需改动, 但玩家坐标已被 clamp
      });

      // ----- 初始化游戏 -----
      function initGame() {
        // 1. 先设置画布尺寸
        resizeCanvas();

        // 2. 玩家初始位置 (中心)
        playerX = canvas.width / 2;
        playerY = canvas.height / 2;
        targetX = playerX;
        targetY = playerY;

        // 3. 生成星星 (避开玩家初始位置)
        stars = initStars(STAR_COUNT, playerX, playerY);

        // 4. 分数归零
        score = 0;

        // 5. 事件绑定 (画布)
        canvas.addEventListener('touchstart', handleTouchStart, { passive: false });
        canvas.addEventListener('touchmove', handleTouchMove, { passive: false });
        canvas.addEventListener('touchend', handleTouchEnd);
        canvas.addEventListener('touchcancel', handleTouchEnd);

        canvas.addEventListener('mousedown', handleMouseDown);
        canvas.addEventListener('mousemove', handleMouseMove);
        canvas.addEventListener('mouseup', handleMouseUp);
        canvas.addEventListener('mouseleave', handleMouseLeave);

        // 阻止从画布外释放鼠标导致卡目标 (全局监听mouseup安全)
        window.addEventListener('mouseup', (e) => {
          // 但只当是画布触发的按下才需要, 简单处理: 如果isPointerDown为true就停止
          if (isPointerDown) {
            // 但需要确认不是画布内触发的mouseup? handleMouseUp已经处理, 这里避免二次
            // 但为防止鼠标在画布外松开, 强制停止
            targetX = playerX;
            targetY = playerY;
            isPointerDown = false;
          }
        });

        // 启动游戏循环
        requestAnimationFrame(gameLoop);
      }

      // ----- 游戏更新逻辑 (每帧) -----
      function update() {
        // 1. 平滑移动到目标点
        if (playerX !== targetX || playerY !== targetY) {
          playerX += (targetX - playerX) * MOVE_SPEED;
          playerY += (targetY - playerY) * MOVE_SPEED;

          // 边界防护 (避免极小数溢出)
          playerX = Math.min(Math.max(playerX, 0), canvas.width);
          playerY = Math.min(Math.max(playerY, 0), canvas.height);
        }

        // 2. 碰撞检测 (收集星星)
        for (let i = 0; i < stars.length; i++) {
          const star = stars[i];
          const starAbsX = star.relX * canvas.width;
          const starAbsY = star.relY * canvas.height;

          const dx = starAbsX - playerX;
          const dy = starAbsY - playerY;
          const dist = Math.hypot(dx, dy);

          if (dist < COLLIDE_RADIUS) {
            // 收集到星星: 加分, 生成新星星 (避开玩家当前位置)
            score++;
            
            // 生成一个新星星，不能离玩家太近
            const newStar = createStarAvoidingPlayer(playerX, playerY, COLLIDE_RADIUS, 25);
            stars[i] = newStar;  // 替换当前星星
            // 不break, 继续检查其他星星 (一帧可以收集多个)
          }
        }

        // 小优化: 如果玩家卡在边缘导致目标超出, 强制拉回目标 (极少情况)
        targetX = Math.min(Math.max(targetX, 0), canvas.width);
        targetY = Math.min(Math.max(targetY, 0), canvas.height);
      }

      // ----- 绘制画布 -----
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // 1. 绘制深色背景 (增加一点星空感)
        const gradient = ctx.createRadialGradient(playerX, playerY, 20, playerX, playerY, Math.max(canvas.width, canvas.height));
        gradient.addColorStop(0, '#1e2a3a');
        gradient.addColorStop(1, '#0f172a');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // 2. 绘制星星 (所有)
        for (let s of stars) {
          const x = s.relX * canvas.width;
          const y = s.relY * canvas.height;

          // 闪烁微光效果 (简单)
          ctx.beginPath();
          ctx.arc(x, y, 14, 0, Math.PI * 2);
          ctx.fillStyle = '#FFD966';
          ctx.shadowColor = '#FFAA00';
          ctx.shadowBlur = 18;
          ctx.fill();
          // 内层高光
          ctx.shadowBlur = 8;
          ctx.beginPath();
          ctx.arc(x-2, y-2, 5, 0, Math.PI * 2);
          ctx.fillStyle = '#FFF5B0';
          ctx.fill();
          // 重置阴影避免影响其他绘制
          ctx.shadowBlur = 0;
          ctx.shadowColor = 'transparent';
        }

        // 3. 绘制玩家 (一个发光的能量球)
        ctx.shadowColor = '#4A9EFF';
        ctx.shadowBlur = 30;
        ctx.beginPath();
        ctx.arc(playerX, playerY, 22, 0, Math.PI * 2);
        ctx.fillStyle = '#5A9EFF';
        ctx.fill();
        // 内圈
        ctx.shadowBlur = 20;
        ctx.beginPath();
        ctx.arc(playerX-3, playerY-3, 12, 0, Math.PI * 2);
        ctx.fillStyle = '#FFFFFF';
        ctx.fill();
        // 眼睛效果(小高光)
        ctx.shadowBlur = 0;
        ctx.beginPath();
        ctx.arc(playerX-8, playerY-8, 4, 0, Math.PI * 2);
        ctx.fillStyle = '#FFFFFF';
        ctx.fill();

        // 4. 绘制分数 (左上角, 带半透明背景)
        ctx.shadowBlur = 0;
        ctx.font = 'bold 28px "Segoe UI", "PingFang SC", system-ui, sans-serif';
        ctx.fillStyle = 'rgba(255, 255, 255, 0.9)';
        ctx.fillText(`⭐ ${score}`, 24, 58);
        // 加个底纹
        ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';
        ctx.fillText(`⭐ ${score}`, 28, 62);
        ctx.fillStyle = '#FFFFFF';
        ctx.fillText(`⭐ ${score}`, 24, 58);

        // 5. 简单提示 (小字号)
        ctx.font = '16px system-ui, sans-serif';
        ctx.fillStyle = 'rgba(210, 225, 255, 0.8)';
        ctx.fillText('触摸移动 · 收集星星', 24, canvas.height - 28);
      }

      // ----- 游戏循环 -----
      function gameLoop() {
        update();
        draw();
        requestAnimationFrame(gameLoop);
      }

      // ----- 启动一切 -----
      initGame();
    })();
  </script>
</body>
</html>