<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>王者视距 · 极简小屏版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            padding: 12px;
        }

        .tool-container {
            width: 100%;
            max-width: 340px;
            margin: 0 auto;
            opacity: 1;
        }

        .glass-card {
            background: #ffffff;
            border-radius: 28px;
            padding: 18px 16px 22px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
            border: 1px solid #edf2ef;
        }

        .hero {
            text-align: center;
            margin-bottom: 16px;
        }
        .free-badge {
            display: inline-block;
            background: #fff3e0;
            padding: 3px 10px;
            border-radius: 30px;
            font-size: 10px;
            font-weight: 700;
            color: #c27e2a;
            margin-bottom: 8px;
            border: 0.5px solid #ffe0a3;
        }
        .hero-icon {
            font-size: 36px;
            line-height: 1;
            margin-bottom: 4px;
        }
        .hero h1 {
            font-size: 22px;
            font-weight: 800;
            color: #1f8a5c;
            margin-bottom: 4px;
        }
        .hero-badge {
            font-size: 10px;
            background: #f5faf7;
            padding: 3px 10px;
            border-radius: 30px;
            display: inline-block;
            color: #2c6e4a;
        }

        .action-btn {
            width: 100%;
            padding: 10px 12px;
            margin: 6px 0;
            border-radius: 60px;
            font-size: 14px;
            font-weight: 600;
            text-align: center;
            background: #ffffff;
            border: 1px solid #e2e8e2;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        .action-btn:active {
            transform: scale(0.97);
            background: #fafcfa;
        }
        .btn-primary {
            background: #23b574;
            color: white;
            border: none;
        }
        .channel-btn {
            background: #1e2f3c;
            color: #ffecb3;
            border: 1px solid #3e5a6b;
        }
        .active-special {
            background: #e2f3e9;
            border: 1.5px solid #23b574;
            color: #136b45;
        }

        .divider {
            height: 1px;
            background: #edf2ef;
            margin: 14px 0 12px;
        }

        .footer-note {
            font-size: 10px;
            text-align: center;
            color: #6c757d;
            margin-top: 14px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            padding: 4px 0;
        }
        .footer-note a {
            color: #1f8a5c;
            text-decoration: none;
            font-weight: 500;
        }

        /* 验证弹窗（简单内嵌，不依赖外部状态栏） */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }
        .modal-card {
            width: 86%;
            max-width: 300px;
            background: #ffffff;
            border-radius: 32px;
            padding: 20px 18px 24px;
            text-align: center;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
            border: 1px solid #e0e7e0;
        }
        .modal-icon {
            font-size: 40px;
            margin-bottom: 6px;
        }
        .modal-card h3 {
            font-size: 20px;
            font-weight: 800;
            color: #1f8a5c;
            margin-bottom: 8px;
        }
        .modal-warning {
            font-size: 12px;
            background: #fefaf0;
            padding: 10px;
            border-radius: 20px;
            text-align: left;
            margin: 12px 0;
            border-left: 3px solid #23b574;
            line-height: 1.4;
            color: #2b4e3a;
        }
        .input-group {
            margin: 12px 0 10px;
        }
        .input-group input {
            width: 100%;
            padding: 10px 14px;
            border-radius: 60px;
            border: 1.5px solid #d4dcd4;
            background: #ffffff !important;
            font-size: 14px;
            text-align: center;
            font-weight: 500;
            outline: none;
            color: #1a2e24;
            box-shadow: none;
            -webkit-appearance: none;
        }
        .input-group input:focus {
            border-color: #23b574;
            box-shadow: 0 0 0 2px rgba(35, 181, 116, 0.1);
            background: #ffffff !important;
        }
        .modal-btn {
            background: #23b574;
            width: 100%;
            padding: 10px;
            border-radius: 60px;
            border: none;
            color: white;
            font-weight: bold;
            font-size: 15px;
            margin-top: 6px;
            cursor: pointer;
        }
        .modal-btn:active {
            transform: scale(0.97);
            background: #1a8c5a;
        }
        .error-tip {
            font-size: 10px;
            color: #e67e22;
            margin-top: 4px;
        }
        .modal-footer-note {
            font-size: 9px;
            margin-top: 10px;
            color: #7c8c7c;
        }
    </style>
</head>
<body>

<!-- 验证弹窗（必须同意才能看到主界面） -->
<div id="entryModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-icon">🔴🟡🟢</div>
        <h3>仅供学习 · 禁止传播</h3>
        <div class="modal-warning">
            🔓 永久免费 · 仅学习交流<br>
            🚫 严禁任何贩卖行为，一经发现封禁<br>
            🛡️ 修改视距风险自负，请遵守游戏规则<br>
            💎 本工具永不收费，谨防受骗
        </div>
        <div class="input-group">
            <input type="text" id="confirmInput" placeholder="输入「OK」同意条款" autocomplete="off">
            <div id="modalError" class="error-tip"></div>
        </div>
        <button class="modal-btn" id="confirmBtn">✅ 确认进入 · 免费使用</button>
        <div class="modal-footer-note">✊ 加入频道获取免费教程</div>
    </div>
</div>

<!-- 主工具界面（初始隐藏） -->
<div id="mainTool" class="tool-container" style="display: none;">
    <div class="glass-card">
        <div class="hero">
            <div class="free-badge"> 💎𝐓𝐆频道@𝐢𝐎𝐒𝐀𝐖𝐉 </div>
            <div class="hero-icon">🈲️禁止任何盗卖</div>
            <h1> 王者·𝐒𝟒𝟑视距 </h1>
            <div class="hero-badge">自定义视距 · 流畅高帧</div>
        </div>

        <button id="button1" class="action-btn btn-primary">
            🌟 ① 2.0倍视距
        </button>
        <button id="button2" class="action-btn">
            🎛️ ② 自定义视距 (0.1~9.9)
        </button>

        <div class="divider"></div>

        <button id="tgChannelBtn" class="action-btn channel-btn">
            ✈️ 加入 TG 频道 · 免费资源
        </button>

        <div class="footer-note">
            <span>© 2026 爱玩机</span>
            <span>🌹 学习研究</span>
            <a href="#" id="fakeChannelLink">📢 免费加入</a>
        </div>
    </div>
</div>

<script>
    // ---------- 极简版：无状态栏，后台静默检测 ----------
    let isActive1 = false;
    let isActive2 = false;
    let gameProcess = null;
    let memoryBase = null;
    let checkInterval = null;

    // DOM 元素
    const entryModal = document.getElementById('entryModal');
    const confirmInput = document.getElementById('confirmInput');
    const confirmBtn = document.getElementById('confirmBtn');
    const modalError = document.getElementById('modalError');
    const mainTool = document.getElementById('mainTool');

    const channelUrl = "https://t.me/iOSAWJ";

    // 绑定频道按钮
    document.getElementById('tgChannelBtn')?.addEventListener('click', () => window.open(channelUrl, '_blank'));
    document.getElementById('fakeChannelLink')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.open(channelUrl, '_blank');
    });

    // 静默检测游戏进程和基址
    function checkProcessAndMemory() {
        return new Promise((resolve, reject) => {
            try {
                if (typeof h5gg === 'undefined') {
                    reject("h5gg missing");
                    return;
                }
                const procs = h5gg.getProcList();
                gameProcess = procs.find(p => p && (p.name === "smoba" || (p.name && p.name.toLowerCase().includes("smoba"))));
                if (!gameProcess) {
                    reject("no process");
                    return;
                }
                h5gg.setTargetProc(gameProcess.pid);
                h5gg.clearResults();
                const ranges = h5gg.getRangesList('UnityFramework');
                if (ranges && ranges.length > 0) {
                    memoryBase = ranges[0].start;
                    resolve(true);
                } else {
                    reject("no range");
                }
            } catch(e) {
                reject(e);
            }
        });
    }

    // 修改视距（原始偏移链）
    function setCameraDistance(val) {
        if (!gameProcess || !memoryBase) {
            alert("游戏未连接，请先启动王者荣耀并进入游戏");
            return false;
        }
        try {
            const baseAddr = Number(memoryBase) + 0x12ACEE98;
            const ptr1 = h5gg.getValue(baseAddr, 'I64');
            if (!ptr1) throw new Error("读取指针失败");
            const ptr2 = h5gg.getValue(Number(ptr1) + 0xB8, 'I64');
            if (!ptr2) throw new Error("读取二级指针失败");
            const finalAddr = Number(ptr2) + 0x29C;
            h5gg.setValue(finalAddr, val, 'F32');
            return true;
        } catch(e) {
            alert("修改视距失败: " + e.message);
            return false;
        }
    }

    // 2.0倍按钮逻辑
    function toggleMenu1() {
        const btn1 = document.getElementById('button1');
        if (!gameProcess || !memoryBase) {
            alert("请先启动王者荣耀并进入游戏");
            return;
        }
        if (!isActive1) {
            if (setCameraDistance(2.0)) {
                isActive1 = true;
                btn1.classList.add('active-special');
                btn1.innerHTML = '✅ ① 2.0倍 · 已激活';
                if (isActive2) {
                    const btn2 = document.getElementById('button2');
                    btn2.classList.remove('active-special');
                    btn2.innerHTML = '🎛️ ② 自定义视距 (0.1~9.9)';
                    isActive2 = false;
                }
                alert("2.0倍视距已激活");
            }
        } else {
            if (confirm("关闭2.0倍视距？恢复默认请重进游戏")) {
                isActive1 = false;
                btn1.classList.remove('active-special');
                btn1.innerHTML = '🌟 ① 2.0倍视距';
                alert("2.0倍视距已关闭");
            }
        }
    }

    // 自定义视距按钮逻辑
    function toggleMenu2() {
        const btn2 = document.getElementById('button2');
        if (!gameProcess || !memoryBase) {
            alert("请先启动王者荣耀并进入游戏");
            return;
        }
        let input = prompt("请输入视距倍数 (0.1~9.9)", "2.2");
        if (input === null) return;
        let val = parseFloat(input);
        if (isNaN(val) || val < 0.1 || val > 9.9) {
            alert("请输入 0.1~9.9 之间的数字");
            return;
        }
        if (setCameraDistance(val)) {
            if (isActive1) {
                const btn1 = document.getElementById('button1');
                btn1.classList.remove('active-special');
                btn1.innerHTML = '🌟 ① 2.0倍视距';
                isActive1 = false;
            }
            isActive2 = true;
            btn2.classList.add('active-special');
            btn2.innerHTML = `🎯 ② 自定义[${val}x] · 生效`;
            alert(`自定义视距 ${val}x 已生效`);
        }
    }

    // 初始化主界面（验证通过后调用）
    function initAfterVerify() {
        // 显示主界面
        mainTool.style.display = 'block';
        // 绑定按钮事件（确保只绑定一次）
        const btn1 = document.getElementById('button1');
        const btn2 = document.getElementById('button2');
        if (btn1 && !btn1.hasListener) {
            btn1.addEventListener('click', toggleMenu1);
            btn2.addEventListener('click', toggleMenu2);
            btn1.hasListener = true;
            btn2.hasListener = true;
        }

        // 启动静默后台检测（每 5 秒尝试一次，不干扰用户）
        const attemptConnect = () => {
            checkProcessAndMemory().catch(() => {});
        };
        attemptConnect(); // 立即尝试一次
        if (checkInterval) clearInterval(checkInterval);
        checkInterval = setInterval(() => {
            if (!gameProcess || !memoryBase) {
                attemptConnect();
            }
        }, 5000);
    }

    // 验证弹窗逻辑
    function verifyAndEnter() {
        const userInput = confirmInput.value.trim();
        if (userInput === "OK") {
            entryModal.style.display = 'none';
            initAfterVerify();
        } else {
            modalError.innerText = "⚠️ 请输入「OK」确认条款";
            confirmInput.style.borderColor = "#e67e22";
            setTimeout(() => {
                modalError.innerText = "";
                confirmInput.style.borderColor = "#d4dcd4";
            }, 1500);
        }
    }

    confirmBtn.addEventListener('click', verifyAndEnter);
    confirmInput.addEventListener('keypress', (e) => { if(e.key === 'Enter') verifyAndEnter(); });

    // 页面关闭时清理定时器
    window.addEventListener('beforeunload', () => {
        if (checkInterval) clearInterval(checkInterval);
    });
</script>
</body>
</html>